# Copy this file to `.env` and adjust if needed.

# Neon Postgres connection string — copy the "psql / connection string" value
# from your Neon project dashboard, then change its scheme from
# postgresql:// or postgres:// to postgresql+psycopg2:// and keep sslmode=require
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxxx-pooler.region.aws.neon.tech/home_rental?sslmode=require

# Secret used to sign JWT auth tokens - change this in real deployments
JWT_SECRET=change-this-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
